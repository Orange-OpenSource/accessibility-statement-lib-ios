sults of the accessibility audits","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"someURL"}]},{"text":" can be an absolute URL of an HTML file displaying a detailed page, or an external HTML page","type":"text"}]}]}]},{"type":"aside","name":"Tip","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Note you can use La Va11ydette to generate such XML file (https:\/\/la-va11ydette.orange.com\/)"}]}],"style":"tip"},{"type":"paragraph","inlineContent":[{"type":"text","text":"More complete sample with OUDS library:"}]},{"type":"codeListing","code":["import DeclarationAccessibility","","struct AccessibilityStatementPage: View {","","    let detailsPageURL: URL","    @Environment(\\.theme) var theme \/\/ Supposed the theme has been initialized","","    init() {","        guard let detailsPageURL = Bundle.main.url(forResource: \"accessibility_detail\", withExtension: \"html\") else {","            fatalError(\"Unable to find accessibility_detail.html in resources\")","        }","","        self.detailsPageURL = detailsPageURL","    }","","    var body: some View {","        VStack {","            \/\/ Supposed to have \"accessibility_result\" XML file in app bundle","            \/\/ Here load a local HTML page (\"accessibility_detail\" HTML file in app bundle), forced to be in webview","            StatementView(xmlFileName: \"accessibility_result\", localURL: detailsPageURL.absoluteString, theme: theme)","        }","    }","}"],"syntax":"swift"},{"text":"Data and privacy","type":"heading","anchor":"Data-and-privacy","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"emphasis","inlineContent":[{"type":"text","text":"accessibility-statement-lib-ios"}]},{"type":"text","text":" library is a Software Development Kit (SDK) that allows developpers to display accessibility statement on mobile applications."},{"type":"text","text":" "},{"type":"text","text":"As such:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"this SDK does not handle any personnal data","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"this SDK does not require any device permission to work","type":"text"}]}]}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/declarationaccessibility"]}],"references":{"https://github.com/Orange-OpenSource/accessibility-statement-lib-ios/blob/develop/MIGRATION.md":{"identifier":"https:\/\/github.com\/Orange-OpenSource\/accessibility-statement-lib-ios\/blob\/develop\/MIGRATION.md","title":"a look on the migration guide for v2","type":"link","titleInlineContent":[{"text":"a look on the migration guide for v2","type":"text"}],"url":"https:\/\/github.com\/Orange-OpenSource\/accessibility-statement-lib-ios\/blob\/develop\/MIGRATION.md"},"doc://DeclarationAccessibility/documentation/DeclarationAccessibility/Foundation":{"abstract":[],"kind":"symbol","identifier":"doc:\/\/DeclarationAccessibility\/documentation\/DeclarationAccessibility\/Foundation","url":"\/documentation\/declarationaccessibility\/foundation","role":"collection","type":"topic","title":"Foundation"},"doc://DeclarationAccessibility/documentation/DeclarationAccessibility/Theme":{"identifier":"doc:\/\/DeclarationAccessibility\/documentation\/DeclarationAccessibility\/Theme","title":"Theme","kind":"symbol","deprecated":true,"url":"\/documentation\/declarationaccessibility\/theme","role":"symbol","abstract":[{"text":"A theme to apply to accessibility statement","type":"text"}],"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"Theme"}],"type":"topic","navigatorTitle":[{"kind":"identifier","text":"Theme"}]},"doc://DeclarationAccessibility/documentation/DeclarationAccessibility":{"type":"topic","url":"\/documentation\/declarationaccessibility","role":"collection","abstract":[]