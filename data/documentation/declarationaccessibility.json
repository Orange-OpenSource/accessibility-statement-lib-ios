{"topicSections":[{"title":"Enumerations","generated":true,"anchor":"Enumerations","identifiers":["doc:\/\/DeclarationAccessibility\/documentation\/DeclarationAccessibility\/Theme"]},{"title":"Extended Modules","generated":true,"anchor":"Extended-Modules","identifiers":["doc:\/\/DeclarationAccessibility\/documentation\/DeclarationAccessibility\/Foundation"]}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"This is a library, exposed as a Swift Package, which will help you to display a legal accessibility statement for your application.","type":"text"},{"text":" ","type":"text"},{"text":"This library use XML report which can be generated from ","type":"text"},{"type":"reference","identifier":"https:\/\/la-va11ydette.orange.com\/?lang=en","isActive":true},{"text":".","type":"text"}]},{"type":"aside","style":"tip","content":[{"type":"paragraph","inlineContent":[{"text":"Feel free to submit pull requests if you can improve the support of any platforms!","type":"text"}]}],"name":"Tip"},{"type":"aside","style":"important","content":[{"type":"paragraph","inlineContent":[{"text":"You used until now the version 1? Have ","type":"text"},{"identifier":"https:\/\/github.com\/Orange-OpenSource\/accessibility-statement-lib-ios\/blob\/develop\/MIGRATION.md","isActive":true,"type":"reference"}]}],"name":"Important"},{"type":"heading","level":2,"text":"How to use the library","anchor":"How-to-use-the-library"},{"type":"paragraph","inlineContent":[{"text":"When you get the dependency, import from the Swift Package the dedicated product:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["import DeclarationAccessibility"]},{"type":"paragraph","inlineContent":[{"text":"You can integrate the dedicated ","type":"text"},{"type":"codeVoice","code":"View"},{"text":" in your app, e.g. in about pages:","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"with local HTML file:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["StatementView(xmlFileName: fileName, theme: .orange, localURL: someURL)"]},{"type":"paragraph","inlineContent":[{"text":"or if you use ","type":"text"},{"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios","isActive":true},{"text":" library, prefer instead:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["StatementView(xmlFileName: fileName, localURL: someURL, theme: theme)"]},{"type":"paragraph","inlineContent":[{"text":"You can also load an external HTML page for details:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["StatementView(xmlFileName: fileName, theme: .orange, remoteUrl: someURL, useWebView: true)"]},{"type":"paragraph","inlineContent":[{"text":"or if you use ","type":"text"},{"overridingTitleInlineContent":[{"text":"OUDS","type":"text"}],"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios","overridingTitle":"OUDS","isActive":true},{"text":" library, prefer instead:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["StatementView(xmlFileName: fileName, remoteUrl: someURL, useWebView: true, theme: theme)"]},{"type":"paragraph","inlineContent":[{"text":"where:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"fileName","type":"text"}],"type":"emphasis"},{"text":" is the name of the XML file containing the results of the accessibility audits","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"someURL","type":"text"}],"type":"emphasis"},{"text":" can be an absolute URL of an HTML file displaying a detailed page, or an external HTML page","type":"text"}],"type":"paragraph"}]}]},{"type":"aside","style":"tip","content":[{"type":"paragraph","inlineContent":[{"text":"Note you can use La Va11ydette to generate such XML file (https:\/\/la-va11ydette.orange.com\/)"