{"topicSections":[{"anchor":"Enumerations","generated":true,"title":"Enumerations","identifiers":["doc:\/\/DeclarationAccessibility\/documentation\/DeclarationAccessibility\/Theme"]},{"anchor":"Extended-Modules","generated":true,"title":"Extended Modules","identifiers":["doc:\/\/DeclarationAccessibility\/documentation\/DeclarationAccessibility\/Foundation"]}],"kind":"symbol","metadata":{"symbolKind":"module","roleHeading":"Swift Package","title":"Welcome to the Accessibility Statement Library for iOS","modules":[{"name":"Welcome to the Accessibility Statement Library for iOS"}],"role":"collection","externalID":"DeclarationAccessibility"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/DeclarationAccessibility\/documentation\/DeclarationAccessibility"},"sections":[],"hierarchy":{"paths":[[]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"content":[{"text":"Overview","type":"heading","anchor":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is a library, exposed as a Swift Package, which will help you to display a legal accessibility statement for your application."},{"type":"text","text":" "},{"type":"text","text":"This library use XML report which can be generated from "},{"identifier":"https:\/\/la-va11ydette.orange.com\/?lang=en","isActive":true,"type":"reference"},{"type":"text","text":"."}]},{"type":"aside","name":"Tip","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Feel free to submit pull requests if you can improve the support of any platforms!"}]}],"style":"tip"},{"type":"aside","name":"Important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You used until now the version 1? Have "},{"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/accessibility-statement-lib-ios\/blob\/develop\/MIGRATION.md","isActive":true}]}],"style":"important"},{"text":"How to use the library","type":"heading","anchor":"How-to-use-the-li